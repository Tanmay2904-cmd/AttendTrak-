# Environment Variables Configuration

# Google Sheets Configuration
# Create a Google Cloud Project and enable Sheets API
# Get your Sheet ID from the URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
# Generate an API key from Google Cloud Console
# Note: Vite requires VITE_ prefix for environment variables

VITE_GOOGLE_SHEET_ID=your_sheet_id_here
VITE_GOOGLE_SHEETS_API_KEY=your_api_key_here

# Firebase Configuration (if using Firebase)
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
REACT_APP_FIREBASE_PROJECT_ID=your_firebase_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id

# Backend API (if using backend server)
REACT_APP_API_URL=http://localhost:3000/api
